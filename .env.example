OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Supabase (Dashboard → Project Settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_or_anon_key

# Server-only: Database → Connection string (URI), prefer Transaction pooler :6543
DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Server-only: Settings → API → service_role (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional SMTP defaults — usually saved in the UI for user sends
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Contact form notifications (subscription inquiries → your inbox)
CONTACT_TO_EMAIL=shantanujain18@gmail.com
# Prefer dedicated CONTACT_SMTP_* ; falls back to SMTP_* above if unset
CONTACT_SMTP_HOST=smtp.gmail.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=your-gmail@gmail.com
CONTACT_SMTP_PASS=your-gmail-app-password
CONTACT_SMTP_FROM=ReachPod <your-gmail@gmail.com>

# Extension version gate lives in Postgres table extension_config (migration 005 / 007).
# Example when shipping a new Chrome build:
#   update public.extension_config
#   set required_version = '2.2.0',
#       update_url = 'https://github.com/Shantanujain18/linkedin_post_scrapper/raw/main/dist.zip',
#       message = 'Please install ReachPod 2.2.0 to continue.',
#       updated_at = now()
#   where id = 1;
# Also bump version in chrome-extension/package.json + manifest.json (+ public/manifest.json).
# Dashboard banner uses EXTENSION in lib/constants.ts.
