OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Supabase (Dashboard → Project Settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_or_anon_key

# Server-only: Database → Connection string (URI), prefer Transaction pooler :6543
DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Server-only: Settings → API → service_role (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional SMTP defaults — usually saved in the UI
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
